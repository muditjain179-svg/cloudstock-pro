{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account details including role",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "salesman"] }
      },
      "required": ["email", "role"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Product brand identification",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category grouping",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Item": {
      "title": "Inventory Item",
      "description": "Product catalog and main stock level",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "unit": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "openingBalance": { "type": "number" },
        "mainStock": { "type": "number" },
        "lowStockThreshold": { "type": "number" }
      },
      "required": ["name", "category", "brand", "unit", "purchasePrice", "sellingPrice", "openingBalance", "mainStock"]
    },
    "SalesmanInventory": {
      "title": "Salesman Stock",
      "description": "Stock held by a specific salesman for an item",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "quantity": { "type": "number" }
      },
      "required": ["itemId", "quantity"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer library for sales",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier library for purchases",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name", "phone"]
    },
    "Bill": {
      "title": "Transaction Bill",
      "description": "Records of sales, purchases, or transfers",
      "type": "object",
      "properties": {
        "billNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["sale", "purchase", "transfer", "opening-stock"] },
        "date": { "type": "string", "format": "date-time" },
        "entityId": { "type": "string" },
        "entityName": { "type": "string" },
        "entityPhone": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "oldDue": { "type": "number" },
        "totalAmount": { "type": "number" },
        "receivedAmount": { "type": "number" },
        "newBalance": { "type": "number" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "finalized"] }
      },
      "required": ["billNumber", "type", "date", "items", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/brands/{brandId}": {
      "schema": "Brand",
      "description": "Product brands"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Global item catalog and main inventory"
    },
    "/inventories/{salesmanId}/items/{itemId}": {
      "schema": "SalesmanInventory",
      "description": "Salesman-wise stock tracking"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer list"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Supplier list"
    },
    "/bills/{billId}": {
      "schema": "Bill",
      "description": "Sales, purchases, and transfer history"
    }
  }
}
