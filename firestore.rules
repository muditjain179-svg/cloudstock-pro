rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity test
    match /_connection_test_/{testId} {
      allow read: if true;
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      // Only admins can create/update other users, but users can create their own profile during signup
      allow write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // Catalog Data (Brands, Categories, Items)
    match /brands/{brandId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow writing stock updates during sales/purchases
    }

    // Inventories (Salesman Stock)
    match /inventories/{salesmanId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(salesmanId) || isAdmin());
      
      match /items/{itemId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (isOwner(salesmanId) || isAdmin());
      }
    }

    // Customers & Suppliers
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Bills (Sales, Purchases, Transfers)
    match /bills/{billId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      // Allow deletion if the user is an admin
      // In this app, admins manage the overall inventory and can rollback bills
      allow delete: if isAdmin();
    }
  }
}
