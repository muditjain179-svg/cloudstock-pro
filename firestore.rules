rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'muditjain179@gmail.com');
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isStaticAdmin() {
      return isSignedIn() && request.auth.token.email == 'muditjain179@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (isStaticAdmin() || (userExists() && getUserData().get('role', 'salesman') == 'admin')) && isEmailVerified();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATION HELPERS ---
    function isValidItem(data) {
      return data.get('name', '') is string && data.get('name', '').size() <= 200 &&
             data.get('mainStock', 0) is number;
    }

    function isValidStockAdjustment(data) {
      return data.get('itemId', '') is string &&
             data.get('oldStock', 0) is number &&
             data.get('newStock', 0) is number &&
             data.get('adjustedBy', '') == request.auth.uid &&
             data.get('timestamp', request.time) is timestamp;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // IMPORTANT: After editing publish rules in Firebase Console
    // Firestore Database → Rules → Paste → Publish

    // Users
    match /users/{userId} {
      allow get: if isSignedIn(); // Allow fetching any user info (for names in lists)
      allow list: if isAdmin(); // Allow admins to list staff
      allow create: if isStaticAdmin() || (isAdmin() && incoming().role in ['admin', 'salesman']);
      allow update: if isStaticAdmin() || 
        (isOwner(userId) && incoming().role == existing().role) || // User can update self but not role
        isAdmin();
      allow delete: if isAdmin();
    }

    // Catalog Data (Brands, Categories, Items)
    match /brands/{brandId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    match /categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    match /items/{itemId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() && isValidItem(incoming());
      allow update: if (isAdmin() || isSignedIn()) && (
        // Only allow stock updates for common users, or everything for admin
        (isAdmin() && isValidItem(incoming())) ||
        (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['mainStock']))
      );
      allow delete: if isAdmin();
    }

    // Inventories (Salesman Stock)
    match /inventories/{salesmanId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(salesmanId) || isAdmin());
      
      match /items/{itemId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (isOwner(salesmanId) || isAdmin());
      }
    }

    // Customers & Suppliers
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Bills (Sales, Purchases, Transfers)
    match /bills/{billId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Stock Adjustments (Admin logs for Excel import)
    match /stock_adjustments/{adjustmentId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidStockAdjustment(incoming());
    }
  }
}
