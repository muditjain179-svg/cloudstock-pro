rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connectivity test
    match /_connection_test_/{testId} {
      allow read: if true;
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId);
    }

    // Brands & Categories
    match /brands/{brandId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // In this simple internal app, usually any user can add brands/categories
    }
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Items
    match /items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    // Inventories
    match /inventories/{salesmanId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /items/{itemId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // Customers & Suppliers
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Bills
    match /bills/{billId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // For status changes
    }
  }
}
